rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin") ||
        request.auth.token.email == "ezrahbosire1@gmail.com"
      ); 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collections ---

    // 1. User Profiles
    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isSignedIn() && request.auth.uid == userId && isValidUser(incoming())) || isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['fullName', 'email', 'role', 'active']) &&
               data.fullName is string && data.fullName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'staff'] &&
               data.active is bool;
      }
    }

    // 2. Inventory Products
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if (isAdmin() && isValidProduct(incoming())) ||
                     (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin();

      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'stock', 'category', 'sku']) &&
               data.name is string && data.name.size() <= 200 &&
               data.price is number &&
               data.stock is number &&
               data.category is string &&
               data.sku is string;
      }
    }

    // 3. Sales Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.staffId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.staffId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin();

      function isValidOrder(data) {
        return data.keys().hasAll(['staffId', 'items', 'totalAmount', 'paymentStatus', 'orderStatus']) &&
               data.staffId == request.auth.uid &&
               data.items is list && data.items.size() > 0 &&
               data.totalAmount is number &&
               data.paymentStatus is string &&
               data.orderStatus is string;
      }
    }

    // 4. Chat Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }

    // 5. Global Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Support Feedback
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // 7. Customers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming());
      allow update: if isSignedIn() && isValidCustomer(incoming());
      allow delete: if isAdmin();

      function isValidCustomer(data) {
        return data.name is string && data.phone is string;
      }
    }

    // 8. Expenses
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isAdmin() && isValidExpense(incoming());
      allow delete: if isAdmin();

      function isValidExpense(data) {
        return data.amount is number && data.category is string;
      }
    }
  }
}
